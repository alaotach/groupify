{
    "manifest_version": 3,
    "name": "Groupify - Group your tabs",
    "version": "1.0",
    "description": "A Chrome extension to group your tabs based on their content.",
    "permissions": ["activeTab", "scripting", "storage", "tabs", "contextMenus"],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "commands":
    {
        "_execute_action": {
            "suggested_key": {
                "default": "Alt+Shift+O"
            },
            "description": "Open the popup extension"
        },
        "addToGroup": {
            "suggested_key": {
                "default": "Alt+Shift+G"
            },
            "description": "Group tabs based on their content"
        },
        "saveWindow": {
            "suggested_key": {
                "default": "Alt+Shift+S"
            },
            "description": "Save current window as group"
        }
    }
}