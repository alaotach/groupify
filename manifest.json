{
    "manifest_version": 3,
    "name": "Groupify - Group your tabs",
    "version": "1.0",
    "description": "A Chrome extension to group your tabs based on their content.",
    "permissions": ["activeTab", "scripting", "storage", "tabs", "contextMenus"],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    }
}